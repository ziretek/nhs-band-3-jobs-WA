# Copy these values into your shell environment before sending.
# Do not put your real password in this example file.

# Gmail example:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false

# For Gmail, use a Google App Password, not your normal account password.
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-character-app-password

# Defaults used by send_email.py.
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=kennethoseinimako@gmail.com
